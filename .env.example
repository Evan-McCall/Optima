# Required for the agent loop and CSV ingestion.
ANTHROPIC_API_KEY=

# Optional. Raises Semantic Scholar rate limits for live paper search.
# Without it, S2 is still attempted unauthenticated, then falls back to cache.
SEMANTIC_SCHOLAR_API_KEY=

# --- Optional overrides (sensible defaults in optima/config.py) ---

# Your team's industry/domain. Set by `optima init`; appended to every paper
# search so arXiv / Semantic Scholar results stay on-domain.
# OPTIMA_INDUSTRY=legal tech

# Model IDs. Override here to hot-swap if a tag changes or you hit rate limits.
# OPTIMA_MODEL_INTENT=claude-haiku-4-5-20251001
# OPTIMA_MODEL_INGEST=claude-haiku-4-5-20251001
# OPTIMA_MODEL_RESEARCH=claude-sonnet-4-6
# OPTIMA_MODEL_CONTEXT=claude-sonnet-4-6
# OPTIMA_MODEL_SYNTHESIS=claude-sonnet-4-6

# Which store to read/write. Defaults to the committed synthetic demo_data/.
# Point at your real, private workspace (gitignored) to use your own data.
# OPTIMA_STORE_DIR=data
